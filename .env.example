# ─────────────────────────────────────────────
#  DATABASE
# ─────────────────────────────────────────────
POSTGRES_DB=gisdesk
POSTGRES_USER=gisdesk
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# ─────────────────────────────────────────────
#  JWT  — genera con: openssl rand -base64 48
# ─────────────────────────────────────────────
JWT_SECRET=CHANGE_ME_LONG_RANDOM_STRING_MIN_32_CHARS

# ─────────────────────────────────────────────
#  SMTP
# ─────────────────────────────────────────────
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=noreply@example.com
SMTP_PASS=CHANGE_ME
SMTP_FROM=noreply@example.com

# ─────────────────────────────────────────────
#  FRONTEND URL  (usato nei link delle email)
# ─────────────────────────────────────────────
FRONTEND_URL=https://gisdesk.example.com

# ─────────────────────────────────────────────
#  OPENAI  (opzionale — AI Assistant)
# ─────────────────────────────────────────────
OPENAI_API_KEY=
